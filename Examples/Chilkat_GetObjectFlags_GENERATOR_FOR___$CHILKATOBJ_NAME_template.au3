Func _Chilkat_GetObjectFlags($sObject_classname, $CHILKATOBJ_NAME = '')
	Local $oObj = ObjCreate($sObject_classname)
	If @error Then ConsoleWrite('! ---> @error=' & @error & '  @extended=' & @extended & ' : ObjCreate("' & $sObject_classname & '")' & @CRLF)
;~ 	ObjName_FlagsValue($oHtmlToXml)
	ObjName_FlagsValue_Chillkat($oObj, $sObject_classname, $CHILKATOBJ_NAME)
	If @error Then ConsoleWrite('! ---> @error=' & @error & '  @extended=' & @extended & ' : $sObject_classname= ' & $sObject_classname & @CRLF)
EndFunc   ;==>_Chilkat_GetObjectFlags

Func ObjName_FlagsValue_Chillkat(ByRef $oObj, $sObject_classname, $CHILKATOBJ_NAME)
	Local $aRegExp = StringRegExp($sObject_classname, '(.+?)\.', $STR_REGEXPARRAYGLOBALMATCH)
	If @error Then Return SetError(1, @extended, 0)
;~ 	ConsoleWrite("! " & $aRegExp[0]& @CRLF)
	Local $sVersion = '$CHILKATOBJ_VERSION_' & StringRegExpReplace($aRegExp[0], '\D', '')
;~ 	ConsoleWrite("! $sVersion = " & $sVersion & @CRLF)
	$CHILKATOBJ_NAME = "$CHILKATOBJ_NAME_" & $CHILKATOBJ_NAME

	Local $sResult = _
			"$CHILKATOBJ_API[" & $sVersion & "][" & StringUpper($CHILKATOBJ_NAME) & "][$CHILKATOBJ_ID_PROGID]='" & $sObject_classname & "'" & @CRLF & _
			"$CHILKATOBJ_API[" & $sVersion & "][" & StringUpper($CHILKATOBJ_NAME) & "][$CHILKATOBJ_ID_CLSID]='" & ObjName($oObj, $OBJ_CLSID) & "'" & @CRLF & _
			"$CHILKATOBJ_API[" & $sVersion & "][" & StringUpper($CHILKATOBJ_NAME) & "][$CHILKATOBJ_ID_IID]='" & ObjName($oObj, $OBJ_IID) & "'" & @CRLF & _
			@CRLF

	ConsoleWrite($sResult)
EndFunc   ;==>ObjName_FlagsValue_Chillkat

Func ObjName_FlagsValue(ByRef $oObj)
	Local $sInfo = ''

	$sInfo &= '+>' & @TAB & 'ObjName($oObj,1) {The name of the Object} =' & @CRLF & @TAB & ObjName($oObj, $OBJ_NAME) & @CRLF

	; HELPFILE REMARKS: Not all Objects support flags 2 to 7. Always test for @error in these cases.
	$sInfo &= '+>' & @TAB & 'ObjName($oObj,2) {Description string of the Object} =' & @CRLF & @TAB & ObjName($oObj, $OBJ_STRING)
	If @error Then $sInfo &= '@error = ' & @error
	$sInfo &= @CRLF & @CRLF

	$sInfo &= '+>' & @TAB & 'ObjName($oObj,3) {The ProgID of the Object} =' & @CRLF & @TAB & ObjName($oObj, $OBJ_PROGID)
	If @error Then $sInfo &= '@error = ' & @error
	$sInfo &= @CRLF & @CRLF

	$sInfo &= '+>' & @TAB & 'ObjName($oObj,4) {The file that is associated with the object in the Registry} =' & @CRLF & @TAB & ObjName($oObj, $OBJ_FILE)
	If @error Then $sInfo &= '@error = ' & @error
	$sInfo &= @CRLF & @CRLF

	$sInfo &= '+>' & @TAB & 'ObjName($oObj,5) {Module name in which the object runs (WIN XP And above). Marshaller for non-inproc objects.} =' & @CRLF & @TAB & ObjName($oObj, $OBJ_MODULE)
	If @error Then $sInfo &= '@error = ' & @error
	$sInfo &= @CRLF & @CRLF

	$sInfo &= '+>' & @TAB & 'ObjName($oObj,6) {CLSID of the object''s coclass} =' & @CRLF & @TAB & ObjName($oObj, $OBJ_CLSID)
	If @error Then $sInfo &= '@error = ' & @error
	$sInfo &= @CRLF & @CRLF

	$sInfo &= '+>' & @TAB & 'ObjName($oObj,7) {IID of the object''s interface} =' & @CRLF & @TAB & ObjName($oObj, $OBJ_IID)
	If @error Then $sInfo &= '@error = ' & @error
	$sInfo &= @CRLF & @CRLF

	ConsoleWrite($sInfo & @CRLF)


EndFunc   ;==>ObjName_FlagsValue
